<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="createSequence-card_audit_revision_seq" author="Ryzen">
        <createSequence incrementBy="1" sequenceName="card_audit_revision_seq" startValue="1"/>
    </changeSet>

    <changeSet id="createTable-card_account_aud" author="Ryzen">
        <createTable tableName="card_account_aud">
            <column name="rev" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_card_account_aud"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
            <column name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_card_account_aud"/>
            </column>
            <column name="balance" type="DECIMAL"/>
        </createTable>
    </changeSet>

    <changeSet id="createTable-cards_aud" author="Ryzen">
        <createTable tableName="cards_aud">
            <column name="rev" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_cards_aud"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
            <column name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_cards_aud"/>
            </column>
            <column name="user_id" type="BIGINT"/>
            <column name="card_acciount_id" type="BIGINT"/>
            <column name="card_name" type="VARCHAR(255)"/>
            <column name="card_number" type="bytea"/>
            <column name="expiry_date" type="DATE"/>
            <column name="status" type="VARCHAR(255)"/>
            <column name="is_deleted" type="BOOLEAN"/>
        </createTable>
    </changeSet>

    <changeSet id="createTable-transfer_aud" author="Ryzen">
        <createTable tableName="transfer_aud">
            <column name="rev" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_transfer_aud"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
            <column name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_transfer_aud"/>
            </column>
            <column name="from_account_id" type="BIGINT"/>
            <column name="to_account_id" type="BIGINT"/>
            <column name="amount" type="DECIMAL"/>
            <column name="status" type="VARCHAR(255)"/>
            <column name="created_at" type="DATETIME"/>
        </createTable>
    </changeSet>

    <changeSet id="createTable-users_aud" author="Ryzen">
        <createTable tableName="users_aud">
            <column name="rev" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_users_aud"/>
            </column>
            <column name="revtype" type="SMALLINT"/>
            <column name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_users_aud"/>
            </column>
            <column name="username" type="VARCHAR(255)"/>
            <column name="password" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

</databaseChangeLog>